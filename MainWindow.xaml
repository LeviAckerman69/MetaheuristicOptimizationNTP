<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:Components="clr-namespace:MetaheuristicOptimizationNTP.Components"
    x:Class="MetaheuristicOptimizationNTP.MainWindow"
    mc:Ignorable="d"
    Title="MainWindow" Height="550" Width="900">
    <Grid x:Name="MainGrid" Background="Transparent">
        <Border Margin="48,38,178,36" BorderBrush="Black" BorderThickness="2">
            <Components:TownDisplay x:Name="TownDisplay" Margin="23,26,24,34" />
        </Border>

        <Button
            x:Name="ButtonSwap"
            Content="Swap"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,127,40,0"
            Width="80"
            Height="50"
            FontSize="16"/>

        <Button
            x:Name="ButtonInverse"
            Content="Inverse"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,237,40,0"
            Width="80"
            Height="50"
            FontSize="16"/>

        <Button
            x:Name="ButtonScramble"
            Content="Scramble"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,292,40,0"
            Width="80"
            Height="50"
            FontSize="16"/>
        <Button
            x:Name="ButtonInsert"
            Content="Insert"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,182,40,0"
            Width="80"
            Height="50"
            FontSize="16"/>


        <!--<Button x:Name="ButtonMutate" Content="Mutate" HorizontalAlignment="Left" Height="30" Margin="780,127,0,0" VerticalAlignment="Top" Width="60" />-->
        <!--<Button x:Name="ButtonInverse" Content="Inverse" HorizontalAlignment="Left" Margin="780,162,0,0" VerticalAlignment="Top" Height="30" Width="60"/>-->
    </Grid>
</Window>