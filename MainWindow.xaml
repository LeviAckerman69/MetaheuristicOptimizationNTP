<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:Components="clr-namespace:MetaheuristicOptimizationNTP.Components"
    x:Class="MetaheuristicOptimizationNTP.MainWindow"
    mc:Ignorable="d"
    Title="MainWindow"
    Height="550"
    Width="900">
    <Grid
        x:Name="MainGrid"
        Background="Transparent">
        <Border
            Margin="48,38,178,36"
            BorderBrush="Black"
            BorderThickness="2">
            <Components:TownDisplay
                x:Name="TownDisplay"
                Margin="23,26,24,34" />
        </Border>

        <Button
            x:Name="ButtonSwap"
            Content="Swap"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,44,37,0"
            Width="80"
            Height="50"
            FontSize="16" />

        <Button
            x:Name="ButtonInverse"
            Content="Inverse"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,154,37,0"
            Width="80"
            Height="50"
            FontSize="16" />

        <Button
            x:Name="ButtonScramble"
            Content="Scramble"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,209,37,0"
            Width="80"
            Height="51"
            FontSize="16" />

        <Button
            x:Name="ButtonInsert"
            Content="Insert"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,100,37,0"
            Width="80"
            Height="50"
            FontSize="16" />
        <Button
            x:Name="ButtonCreatePopulation"
            Content="Create Population"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,267,6,0"
            Width="153"
            Height="51"
            FontSize="16"/>
        <ListBox
            x:Name="ListPopulation"
            HorizontalAlignment="Left"
            Height="107"
            Margin="741,323,0,0"
            VerticalAlignment="Top"
            Width="149"
            SelectionMode="Single" />

        <Button
            x:Name="ButtonEvolve"
            Content="Evolve"
            HorizontalAlignment="Left"
            Height="51"
            Margin="755,447,0,0"
            VerticalAlignment="Top"
            Width="114" />

        <Label
            x:Name="LabelBest"
            Content="Best Fitness"
            HorizontalAlignment="Left"
            Height="34"
            Margin="64,500,0,0"
            VerticalAlignment="Top"
            Width="118"
            RenderTransformOrigin="0.551,1.24" />

        <Label
            x:Name="LabelAverage"
            Content="Average Fitness"
            HorizontalAlignment="Left"
            Height="34"
            Margin="267,500,0,0"
            VerticalAlignment="Top"
            Width="118" />


        <!--<Button x:Name="ButtonMutate" Content="Mutate" HorizontalAlignment="Left" Height="30" Margin="780,127,0,0" VerticalAlignment="Top" Width="60" />-->
        <!--<Button x:Name="ButtonInverse" Content="Inverse" HorizontalAlignment="Left" Margin="780,162,0,0" VerticalAlignment="Top" Height="30" Width="60"/>-->
    </Grid>
</Window>